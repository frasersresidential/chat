# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
PUBLIC_URL=http://localhost:4000

# ── Auth ────────────────────────────────────────────────────────────────────
# Shared dashboard password (demo-grade). CHANGE THIS in production.
ADSPY_PASSWORD=spy1234
# Secret used to derive session tokens. CHANGE THIS in production.
AUTH_SECRET=change-me-to-a-long-random-string

# ── Meta Ad Library ─────────────────────────────────────────────────────────
# Public competitive intelligence from the Facebook/Meta Ad Library (not scraping).
# Leave blank to explore the dashboard on a built-in mock dataset. Set a token
# (a Meta access token that can call the Ad Library API) to pull real ads.
# https://www.facebook.com/ads/library/api/
META_AD_LIBRARY_TOKEN=
# Default country (ISO-2) for Ad Library searches.
AD_LIBRARY_COUNTRY=TH
# How often (hours) the scheduler re-checks every watched competitor.
REFRESH_HOURS=6

# ── Web Push (optional) ─────────────────────────────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys
# Without these a temporary pair is generated each boot (subscriptions reset).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@adspy.app
