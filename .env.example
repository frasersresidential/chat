# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=http://localhost:3000

# ── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign login tokens (JWT). CHANGE THIS in production.
AUTH_SECRET=change-me-to-a-long-random-string
# Password given to the seeded demo users (login: u_owner@company-a.com)
DEMO_PASSWORD=demo1234

# ── Facebook Messenger ──────────────────────────────────────────────────────
# https://developers.facebook.com/docs/messenger-platform
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_VERIFY_TOKEN=changeme-messenger

# ── Instagram (Messaging via Meta) ──────────────────────────────────────────
# https://developers.facebook.com/docs/messenger-platform/instagram
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=changeme-instagram

# ── TikTok ──────────────────────────────────────────────────────────────────
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── LINE Official Account ───────────────────────────────────────────────────
# https://developers.line.biz/en/docs/messaging-api/
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── X / Twitter ─────────────────────────────────────────────────────────────
# https://developer.twitter.com/en/docs/twitter-api/direct-messages
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_WEBHOOK_SECRET=
